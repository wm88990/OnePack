{
  "$schema": "https://raw.githubusercontent.com/nicedouble/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "OnePack",
  "version": "1.0.0",
  "identifier": "com.onepack.installer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OnePack - 软件安装管理器",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
